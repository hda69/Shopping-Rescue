{
  "name": "shopping-rescue",
  "version": "0.1.0",
  "private": true,
  "description": "Independent SaaS for Google Merchant Center diagnostics",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @shopping-rescue/web dev",
    "dev:worker": "pnpm --filter @shopping-rescue/worker dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @shopping-rescue/database db:migrate",
    "db:seed": "pnpm --filter @shopping-rescue/database db:seed",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "pdf:fixture": "pnpm --filter @shopping-rescue/reporting pdf:fixture",
    "db:reset": "pnpm --filter @shopping-rescue/database db:reset",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
