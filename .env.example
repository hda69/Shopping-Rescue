# =============================================================================
# Shopping Rescue — Environment Variables
# Copy this file to `.env` and fill in values for local development.
# Never commit `.env` — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development

# Public app URL (used in emails, OAuth redirects, Stripe return URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local Docker Postgres (must match docker-compose.yml)
POSTGRES_USER=shopping_rescue
POSTGRES_PASSWORD=shopping_rescue
POSTGRES_DB=shopping_rescue

# PostgreSQL connection string (Supabase or local Docker)
DATABASE_URL=postgresql://shopping_rescue:shopping_rescue@localhost:5432/shopping_rescue

# -----------------------------------------------------------------------------
# Supabase (Auth, optional Storage)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Stripe (Billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe price IDs (configured per plan in Stripe Dashboard)
STRIPE_PRICE_FULL_AUDIT=price_...
STRIPE_PRICE_MONITORING_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# Dev only — unlock reports without Stripe (never enable in production)
BILLING_DEV_UNLOCK=false

# -----------------------------------------------------------------------------
# Google OAuth (Merchant Center connection)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Shopping Rescue <nova.flow.app@gmail.com>

# -----------------------------------------------------------------------------
# Encryption (Google refresh tokens at rest)
# -----------------------------------------------------------------------------
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Optional — previous key for rotation
TOKEN_ENCRYPTION_KEY_PREVIOUS=

# -----------------------------------------------------------------------------
# Cron (weekly monitoring trigger)
# -----------------------------------------------------------------------------
CRON_SECRET=replace_with_long_random_string

# -----------------------------------------------------------------------------
# Observability (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------
WORKER_HEALTH_PORT=3001

# -----------------------------------------------------------------------------
# AI (optional — AI-assisted rule evaluation)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Rate limiting (optional — production)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cron / scheduled tasks
# -----------------------------------------------------------------------------
CRON_SECRET=change-me-in-production
