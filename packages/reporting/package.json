{
  "name": "@shopping-rescue/reporting",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./pdf": "./src/pdf-generator.ts",
    "./pdf/node": "./src/pdf-node.ts"
